# Copy this file to .env and fill in your values
# cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=threat_intel
PG_USER=threat_admin
PG_PASSWORD=changeme

# Role-specific connection strings (used by API per JWT role)
PG_READONLY_USER=threat_readonly
PG_READONLY_PASSWORD=changeme_readonly
PG_CONTRIBUTOR_USER=threat_contributor
PG_CONTRIBUTOR_PASSWORD=changeme_contributor

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=8h

# ── API ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── External Feeds ───────────────────────────────────────
ALIENVAULT_OTX_API_KEY=your_otx_api_key_here
ABUSECH_AUTH_KEY=your_auth_key_here
NVD_API_KEY=your_key_here
# NVD, MITRE ATT&CK, and feeds are public (no key needed, but NVD free API key reduces the rate limiting)

# ── Ingestion Schedule (cron syntax) ─────────────────────
INGEST_CRON=0 */6 * * *   # every 6 hours
